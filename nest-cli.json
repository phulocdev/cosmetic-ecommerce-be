{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "entryFile": "main-v2",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "core/email/templates/**/*.hbs",
        "outDir": "dist/src"
      }
    ],
    "watchAssets": true
  },
  "generateOptions": {
    "spec": false
  }
}
