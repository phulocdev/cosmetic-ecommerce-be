// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ENUMS
enum ProductStatus {
  PUBLISHED
  DRAFT
  ARCHIVED

  @@map("product_status")
}

enum InventoryTransactionStatus {
  DRAFT
  COMPLETED
  CANCELLED

  @@map("inventory_transaction_status")
}

enum DiscountType {
  NONE
  PERCENTAGE
  FIXED_AMOUNT

  @@map("discount_type")
}

enum OrderStatus {
  PROCESSING
  PENDING_PAYMENT
  PAID
  PACKED
  READY_TO_SHIP
  SHIPPED
  COMPLETED
  CANCELLED
  RETURNED
  DELIVERED

  @@map("order_status")
}

enum PaymentMethod {
  COD
  BANKING

  @@map("payment_method")
}

enum UserRole {
  CUSTOMER
  ADMIN
  STAFF

  @@map("user_role")
}

model Product {
  id              String   @id @default(uuid())
  brandId         String
  countryOriginId String

  code        String   @unique
  name        String   
  slug        String   @unique
  description String?   @default("")
  
  status      ProductStatus? @default(PUBLISHED)
  basePrice   Decimal  @db.Decimal(10, 2)
  views       Int? @default(0)

  categories        ProductCategory[]
  brand             Brand           @relation(fields: [brandId], references: [id])
  countryOfOrigin   CountryOfOrigin @relation(fields: [countryOriginId], references: [id])
  variants          ProductVariant[]
  attributes        ProductAttribute[]
  images            ProductImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  @@index([brandId])
  @@index([countryOriginId])
  @@index([status])

  // Composite indexes for cursor pagination
  @@index([createdAt, id])
  @@index([basePrice, id])
  @@index([name, id])
  @@index([views, id])
  @@index([updatedAt, id])

  // Filter optimization
  @@index([status, createdAt])
  @@index([brandId, basePrice])

  @@map("Product")
}

model ProductAttribute {
  id        String @id @default(uuid())
  productId String
  attributeId String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  isRequired  Boolean   @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  @@unique([productId, attributeId])
  @@index([productId])
  @@map("ProductAttribute")
}

