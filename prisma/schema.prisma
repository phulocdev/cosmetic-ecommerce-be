model ProductVariant {
  id String @id @default(uuid())

  productId String

  sku          String @unique
  name         String
  barcode      String @unique
  costPrice    Decimal @db.Decimal(10, 2)
  sellingPrice Decimal @db.Decimal(10, 2)
  stockOnHand  Int // inventory quantity
  imageUrl     String @default("")
  lowStockThreshold Int @default(0)
  maxStockThreshold Int @default(0)
  isActive     Boolean @default(true)

  product                  Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeValues          VariantAttributeValue[]
  image                    VariantImage[]
  inboundTransactionItems  InboundTransactionDetail[]
  outboundTransactionItems OutboundTransactionDetail[]
  orderDetails             OrderDetail[]
  cartItems                CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  @@index([productId])
  @@index([sku])
  @@index([isActive])
  @@index([stockOnHand])
  @@index([sellingPrice])

  // Variant filtering
  @@index([productId, isActive, stockOnHand])
  @@index([productId, sellingPrice])
  @@map("ProductVariant")
}


model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?   @default("")
  parentId    String?   
  
  // Materialized path for performance
  path        String    @default("/")
  depth       Int       @default(0)
  isActive    Boolean   @default(true)
  
  // For sorting within same level
  // sortOrder   Int       @default(0)
  
  parent      Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    ProductCategory[]
  categoryAttributes  CategoryAttribute[]
  
  // SEO fields
  metaTitle       String?
  metaDescription String?
  
  // Soft delete
  isDeleted Boolean @default(false)
  deletedAt DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([parentId])
  @@index([path])
  @@index([slug])
  @@index([isActive])
  @@map("Category")
}

model Brand {
  id String @id @default(uuid())

  name     String @default("")
  imageUrl String @default("")

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  @@map("Brand")
}

model CountryOfOrigin {
  id String @id @default(uuid())

  name String @default("")

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  @@map("CountryOfOrigin")
}

model StockBatch {
  id String @id @default(uuid())

  code String? @unique
  expirationDate DateTime
  importingQuantity Int

  inboundDetails  InboundTransactionDetail[]
  outboundDetails OutboundTransactionDetail[]

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  @@index([expirationDate])
  @@map("StockBatch")
}

model InboundTransaction {
  id String @id @default(uuid())

  supplierId String
  createById String

  code String? @unique
  status InventoryTransactionStatus @default(DRAFT)
  totalImportingPrice Decimal @db.Decimal(10, 2)
  receivedDate DateTime
  note String @default("")

  supplier Supplier @relation(fields: [supplierId], references: [id])
  createBy User @relation("InboundCreator", fields: [createById], references: [id])
  details InboundTransactionDetail[]

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  @@index([supplierId])
  @@index([createById])
  @@index([status])
  @@map("InboundTransaction")
}

model InboundTransactionDetail {
  id String @id @default(uuid())

  productVariantId String
  stockBatchId String
  inboundTransactionId String

  importingPrice Decimal @db.Decimal(10, 2)
  sellingPrice Decimal @db.Decimal(10, 2)
  importingQuantity Int
  totalImportingPrice Decimal @db.Decimal(10, 2)
  discountType DiscountType
  discountValue Decimal @db.Decimal(10, 2)
  note String @default("")

  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])
  stockBatch StockBatch @relation(fields: [stockBatchId], references: [id])
  inboundTransaction InboundTransaction @relation(fields: [inboundTransactionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  @@index([productVariantId])
  @@index([stockBatchId])
  @@index([inboundTransactionId])
  @@map("InboundTransactionDetail")
}

model User {
  id String @id @default(uuid())

  email String @unique
  password String
  code String? @unique
  fullName String? @default("") // when has @default here, the value of this filed can be empty string "" -> nullable
  phoneNumber String? @default("")
  isActive Boolean? @default(true)
  avatarUrl String? @default("")
  role UserRole? @default(CUSTOMER)

  orders Order[]
  cart Cart?
  addresses Address[]
  refreshTokens RefreshToken[]
  passwordResetToken PasswordResetToken?

  createdInboundTransactions InboundTransaction[] @relation("InboundCreator")
  createdOutboundTransactions OutboundTransaction[] @relation("OutboundCreator")

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  @@index([role])
  @@map("User")
}

model Cart {
  id String @id @default(uuid())

  userId String @unique
  user User @relation(fields: [userId], references: [id])

  items CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  @@map("Cart")
}

model CartItem {
  id String @id @default(uuid())

  productVariantId String
  cartId String
  quantity Int

  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])
  cart Cart @relation(fields: [cartId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  @@index([productVariantId])
  @@index([cartId])
  @@map("CartItem")
}

model Order {
  id String @id @default(uuid())

  userId String

  code String? @unique
  status OrderStatus @default(PROCESSING)
  totalPrice Decimal @db.Decimal(10, 2)
  paymentMethod PaymentMethod @default(COD)

  paidAt DateTime?
  deliveredAt DateTime?
  cancelledAt DateTime?

  user User @relation(fields: [userId], references: [id])
  items OrderDetail[]

  shippingInfo ShippingInfo?

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  @@index([userId])
  @@index([status])
  @@map("Order")
}

model ShippingInfo {
  id String @id @default(uuid())

  orderId String @unique

  fullName String @default("")
  email String @unique
  phoneNumber String @unique

  province String @default("")
  district String @default("")
  ward String @default("")
  streetAddress String @default("")
  note String @default("")

  order Order @relation(fields: [orderId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  @@map("ShippingInfo")
}

model Supplier {
  id String @id @default(uuid())

  code        String @unique
  name        String @default("")
  email       String @unique
  phoneNumber String @unique
  address     String @default("")
  note        String @default("")
  companyName String @default("")
  taxCode     String @default("")

  inboundTransactions InboundTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  @@map("Supplier")
}

model OutboundTransaction {
  id String @id @default(uuid())

  createById String

  code String? @unique
  status InventoryTransactionStatus @default(DRAFT)
  totalImportingPrice Decimal @db.Decimal(10, 2)
  exportedDate DateTime
  note String @default("")

  createBy User @relation("OutboundCreator", fields: [createById], references: [id])
  details OutboundTransactionDetail[]

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  @@index([createById])
  @@index([status])
  @@map("OutboundTransaction")
}

model OutboundTransactionDetail {
  id String @id @default(uuid())

  productVariantId String
  stockBatchId String
  outboundTransactionId String

  exportingQuantity Int
  totalImportingPrice Decimal @db.Decimal(10, 2)
  note String @default("")


  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])
  stockBatch StockBatch @relation(fields: [stockBatchId], references: [id])
  outboundTransaction OutboundTransaction @relation(fields: [outboundTransactionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  @@index([productVariantId])
  @@index([stockBatchId])
  @@index([outboundTransactionId])
  @@map("OutboundTransactionDetail")
}

model OrderDetail {
  id String @id @default(uuid())

  orderId String
  productVariantId String

  quantity Int
  productPrice Decimal @db.Decimal(10, 2)

  order Order @relation(fields: [orderId], references: [id])
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  @@index([orderId])
  @@index([productVariantId])
  @@map("OrderDetail")
}

model Address {
  id String @id @default(uuid())

  userId String

  province String @default("")
  district String @default("")
  ward String @default("")
  streetAddress String @default("")
  isDefault Boolean @default(false)

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  @@index([userId])
  @@map("Address")
}

model RefreshToken {
  // Don't use default(uuid()) here, because we need to ensure the same jti between DB and JWT Payloads
  id String @id // JTI synchonized with JWT jti claim (in payload) 
  
  userId String

  hashedToken String @unique // Don't store raw token for security reasons
  expiresAt DateTime
  isRevoked Boolean @default(false) // To manually revoke token by system - when user refresh (logout - remove user's RT instead instead of revoking)
  isUsed Boolean @default(false) // To detect reuse attack - used in Atomic Update when refreshing token

  // Just need this field when you want revoke / remove tokens in a chain (parent, child, grand-child, ...)
  // In realworld application, we will remove all of user's refresh tokens when reuse attack is detected
  // replacedByToken String? 

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt 

  @@index([userId])
  @@map("RefreshToken")
}


model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String @unique
  token     String   @unique  
  
  // One-To-One relationship with User
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@index([userId])
  @@index([token])
  @@map("PasswordResetToken")
}

// Junction table for many-to-many relationship between Product and Category
model ProductCategory {
  productId   String
  categoryId  String
  isPrimary   Boolean   @default(false) // Primary category for breadcrumbs
  
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime  @default(now())
  
  @@id([productId, categoryId])
  @@index([categoryId])
  @@index([productId, isPrimary])
}


// Normalized attribute definitions
model Attribute {
  id          String              @id @default(uuid())
  name        String              @unique // "Color", "Size", "Material" / "Màu sắc" / "Kích thước" / "Chất liệu"
  slug        String              @unique
  type        AttributeType?      @default(TEXT)       // COLOR, SIZE, TEXT, NUMBER

  // Filter-specific fields
  isGlobalFilter  Boolean @default(false) // Show on /collections/all?
  filterGroup     String? // Group filters: "Specifications", "Features", etc.
  unit            String? // "cm", "kg", "GB" for range filters

  values      AttributeValue[]
  products    ProductAttribute[]
  categoryAttributes  CategoryAttribute[] 

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  deletedAt DateTime?
  isDeleted Boolean @default(false)

  @@index([slug])
  @@index([isGlobalFilter])
  @@map("Attribute")
}

enum AttributeType {
  COLOR
  SIZE
  TEXT
  NUMBER
  BOOLEAN
}

model AttributeValue {
  id              String                    @id @default(uuid())
  attributeId     String
  attribute       Attribute                 @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  value           String                    // "Red", "Large", "Cotton"
  hexColor        String?                   // For color swatches: "#FF0000"
  variants        VariantAttributeValue[]
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  deletedAt DateTime?
  isDeleted Boolean @default(false)

  @@unique([attributeId, value])
  @@index([attributeId])
  @@map("AttributeValue")
}

// Junction table: which variant has which attribute values
model VariantAttributeValue {
  id               String          @id @default(uuid())
  variantId        String
  attributeValueId String

  variant          ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attributeValue   AttributeValue  @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  deletedAt DateTime?
  isDeleted Boolean @default(false)

  @@unique([variantId, attributeValueId])
  @@index([variantId])
  @@index([attributeValueId])
  @@map("VariantAttributeValue")
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  url       String
  altText   String?

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  deletedAt DateTime?
  isDeleted Boolean @default(false)

  @@index([productId])
  @@map("ProductImage")
}

model VariantImage {
  id        String         @id @default(uuid())
  variantId String
  url       String
  altText   String?
  
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  createdAt DateTime       @default(now())
  deletedAt DateTime?
  isDeleted Boolean @default(false)

  @@index([variantId])
  @@map("VariantImage")
}

// (Filter Configuration)
model CategoryAttribute {
  id          String    @id @default(uuid())
  categoryId  String
  attributeId String
  
  displayName     String?    // Override attribute name: "Color" → "Shirt Color"
  displayOrder    Int     @default(0)     // Order in filter UI
  filterType      FilterDisplayType @default(CHECKBOX) // CHECKBOX, RADIO, SLIDER, SWATCH
  
  // Behavior flags
  isFilterable    Boolean @default(true)  // Can this be used as a filter?
  isRequired      Boolean    @default(false)  // For product creation

  // Inheritance: if true, child categories inherit this attribute
  inheritToChildren Boolean @default(true)
  
  // Advanced: Filter grouping
  filterGroup     String?    // "Specifications", "Style", "Features"

  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt DateTime?
  isDeleted Boolean @default(false)
  
  @@unique([categoryId, attributeId])
  @@index([categoryId, isFilterable])
  @@index([attributeId])
  @@map("CategoryAttribute")
}

enum FilterDisplayType {
  CHECKBOX      // Multi-select
  RADIO         // Single-select
  SLIDER        // Range (for numbers/prices)
  SWATCH        // Color swatches
  DROPDOWN      // Dropdown select
  TOGGLE        // Boolean (On Sale, Free Shipping)
}

// ============================================
// FILTER CACHE (Performance Layer)
// ============================================
model FilterCache {
  id              String   @id @default(uuid())
  
  // Composite key components
  categoryPath    String   // "/" or "/electronics" or "/electronics/laptops"
  filterHash      String   // MD5 of active filters (for AND logic)
  
  // Cached data structure
  // {
  //   "brands": [{"id": "...", "name": "Nike", "count": 45}],
  //   "attributes": {
  //     "color": [{"id": "...", "value": "Red", "count": 23}],
  //     "size": [{"id": "...", "value": "Large", "count": 12}]
  //   },
  //   "countries": [...],
  //   "priceRange": {"min": 10, "max": 500}
  // }
  aggregatedData  Json
  
  // Metadata
  productCount    Int      @default(0)
  variantCount    Int      @default(0)
  computeTimeMs   Int      @default(0) // Performance monitoring
  
  lastComputedAt  DateTime @default(now())
  expiresAt       DateTime
  deletedAt DateTime?
  isDeleted Boolean @default(false)
  
  @@unique([categoryPath, filterHash])
  @@index([categoryPath])
  @@index([expiresAt])
  @@index([lastComputedAt])
  @@map("FilterCache")
}